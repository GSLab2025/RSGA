cff-version: 1.2.0
title: "RSGA: Reciprocal Space Gated Attention"
message: "If you use this software, please cite it using this metadata or the Zenodo DOI for the corresponding release."
type: software
license: MIT
authors:
  - family-names: Thakur
    given-names: Atul C.
  - family-names: Vazquez-Mayagoitia
    given-names: Alvaro
